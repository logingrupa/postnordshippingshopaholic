includes:
    - ../../../vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 10
    paths:
        - classes
        - components
        - models
        - Plugin.php
    excludePaths:
        - tests
        - updates
        - lang
        - partials
        - assets
    tmpDir: ../../../storage/temp/phpstan/postnordshipping

    universalObjectCratesClasses:
        - Lovata\Toolbox\Classes\Item\ElementItem
